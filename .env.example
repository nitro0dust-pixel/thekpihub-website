# ─────────────────────────────────────────────────────────────────────────────
# KPI Hub Pipeline — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env to git.
# All of these must also be added as GitHub Actions Repository Secrets.
# ─────────────────────────────────────────────────────────────────────────────

# Anthropic (Claude AI)
ANTHROPIC_API_KEY=sk-ant-...

# SerpAPI — used for research + verification
# Get key: https://serpapi.com/
SERPAPI_KEY=...

# Telegram bot notification
# Create bot via @BotFather → get token
# Get chat_id by messaging @userinfobot
TELEGRAM_BOT_TOKEN=123456789:ABC...
TELEGRAM_CHAT_ID=-100...

# WordPress (thekpihub.com)
WP_SITE_URL=https://thekpihub.com
WP_USERNAME=your_wp_username
# Generate at: WP Admin → Users → Your Profile → Application Passwords
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# Optional overrides
# CLAUDE_MODEL=claude-sonnet-4-6   # default; change to claude-opus-4-6 for higher quality
# DRY_RUN=true                      # set to skip WP publish + Telegram (safe for testing)
